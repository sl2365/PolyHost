<Window x:Class="ElementalTracker.SuiteSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Suites" Width="350" Height="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <DockPanel Margin="10">
        <TextBlock x:Name="headerText" DockPanel.Dock="Top" Text="Select suites to include in ReBuild:"
                   FontWeight="Bold" Margin="0,0,0,10" />

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="btnOK" Content="OK" Width="75" Margin="0,0,10,0"
                    Click="OK_Click" IsDefault="True" />
            <Button x:Name="btnCancel" Content="Cancel" Width="75"
                    Click="Cancel_Click" IsCancel="True" />
        </StackPanel>

        <ListBox x:Name="suiteListBox" />
    </DockPanel>
</Window>